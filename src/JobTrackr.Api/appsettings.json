{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=jobtrackr;Username=jobtrackr;Password=jobtrackr"
  },
  "Jwt": {
    "Issuer": "JobTrackr",
    "Audience": "JobTrackr.Clients",
    "Key": "REPLACE_WITH_A_SECRET_OF_AT_LEAST_32_CHARACTERS_FOR_HS256",
    "ExpiresInMinutes": 60
  },
  "Gemini": {
    "ApiKey": "",
    "Model": "gemini-2.5-flash",
    "MaxOutputTokens": 1500,
    "Temperature": 0.7
  },
  "Storage": {
    "Root": "/var/jobtrackr/uploads"
  },
  "AllowedHosts": "*"
}
