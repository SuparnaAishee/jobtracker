# =============================================================================
# JobTrackr — environment template
# =============================================================================
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
# Docker Compose auto-loads `.env` from this folder when you run
#     docker compose up
#
# `.env` is gitignored — keep your secrets out of source control.
# =============================================================================


# ---- Supabase (Postgres) ----------------------------------------------------
# Hosted Postgres. Free tier covers a portfolio project.
#   1. Sign up at https://supabase.com
#   2. New project → choose a region close to you, set + save the DB password.
#   3. Settings → Database → "Connection string" → "Session pooler".
#      Session pooler = port 5432, IPv4, supports prepared statements
#      (which EF Core relies on).
#   4. Paste the host, the username (it includes your project-ref:
#      `postgres.<project-ref>`), and the password you set.
SUPABASE_DB_HOST=aws-0-<region>.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.<your-project-ref>
SUPABASE_DB_PASSWORD=


# ---- API --------------------------------------------------------------------
# Development is fine for the demo; switch to Production when deploying.
ASPNETCORE_ENVIRONMENT=Development
API_PORT=8080
STORAGE_ROOT=/var/jobtrackr/uploads


# ---- JWT --------------------------------------------------------------------
# JWT_KEY MUST be at least 32 characters (HS256 requirement).
# Rotate this if it ever leaks — every existing token will become invalid.
JWT_ISSUER=JobTrackr
JWT_AUDIENCE=JobTrackr.Clients
JWT_KEY=dev-only-change-me-please-must-be-at-least-32-chars-long
JWT_EXPIRES_IN_MINUTES=60


# ---- Gemini (AI assistant) --------------------------------------------------
# Free key: https://aistudio.google.com/apikey  (sign in → "Create API key")
# Leave blank to disable AI features (the app still runs; the AI page
# shows a "not configured" banner and the endpoints return 503).
GEMINI_API_KEY=

# Optional: comma-separated list of keys for automatic rotation when one
# hits its daily quota. Each key is one Google account; rotation lets a
# portfolio demo stay responsive past a single account's free-tier limit.
# Example: GEMINI_API_KEYS=key1,key2,key3
GEMINI_API_KEYS=

GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=4000
GEMINI_TEMPERATURE=0.7


# ---- Web (React + nginx) ----------------------------------------------------
# Host port for the React app. The browser opens http://localhost:${WEB_PORT}.
WEB_PORT=4173
