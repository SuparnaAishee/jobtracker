FROM node:22-alpine AS build
WORKDIR /app

# Optional build arg: when deploying api + web to different origins (e.g. Render),
# set VITE_API_URL to the API base URL so cross-origin calls resolve correctly.
# Leave empty for local docker compose — nginx proxies /api → api container.
ARG VITE_API_URL=
ENV VITE_API_URL=$VITE_API_URL

COPY package.json package-lock.json* ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:1.27-alpine AS final
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
